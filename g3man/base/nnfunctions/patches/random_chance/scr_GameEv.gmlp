meta:
targets = 'gml_GlobalScript_scr_GameEv'
critical = true

patch:
find_line_with('var _Odds = irandom_range(1, 20)')

write_replace('
var _Odds = random_chance(random(100), 20) ? 2 : 0;
')


find_line_with('var _Odds = choose(0, 1)')

write_replace('
var _Odds = random_chance(random(100), 5) ? 1 : 0;
')